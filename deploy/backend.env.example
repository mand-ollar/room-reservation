APP_NAME=room-reservation
DEBUG=false

# Generate: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ADMIN_PASSWORD=change-me-strong-admin-password

# Same-origin via nginx — add your public URL if you access the API directly elsewhere
CORS_ORIGINS=http://localhost,http://127.0.0.1
